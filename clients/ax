#!/usr/bin/env python3
"""ax — thin Axonate CLI for the laptop.

Usage:
  ax "explain this error"                 # model auto
  ax -m claude "write a haiku"            # pick a model
  git diff | ax "review this"             # piped stdin (appended to the prompt)
  ax --no-stream "..."                    # disable streaming
  ax -s work "remember X"; ax -s work "what did I say?"   # session continuity
  ax -s work --new "fresh start"          # reset a session

Config (env or ~/.config/axonate/config):
  AXONATE_URL                gateway base url (default http://127.0.0.1:4100)
  AXONATE_KEY                bearer key (virtual key, or master key in dev)
  AXONATE_CF_CLIENT_ID       Cloudflare Access service-token client id (for api.* edge gate)
  AXONATE_CF_CLIENT_SECRET   Cloudflare Access service-token client secret
"""
import argparse
import json
import os
import sys
import urllib.request

CFG = os.path.expanduser("~/.config/axonate/config")
SESS_DIR = os.path.expanduser("~/.config/axonate/sessions")

# one-shot CLI default: answer directly, assume sensible defaults, never ask back (ax isn't interactive)
DEFAULT_SYSTEM = (
    "You are a non-interactive command-line assistant answering a single shot. The user CANNOT "
    "reply, so NEVER ask clarifying questions and NEVER offer to do follow-up work. If the request "
    "is underspecified, pick the most common sensible defaults and proceed. Do NOT write a plan, "
    "preamble, or 'here is what I'll do' — give the final answer directly. For code requests, "
    "output the complete ready-to-run script in a single code block, with at most one short line of "
    "assumptions above it. Be concise."
)


def load_session(name):
    if not name:
        return []
    path = os.path.join(SESS_DIR, f"{name}.json")
    if os.path.exists(path):
        with open(path) as f:
            return json.load(f)
    return []


def save_session(name, messages):
    if not name:
        return
    os.makedirs(SESS_DIR, exist_ok=True)
    with open(os.path.join(SESS_DIR, f"{name}.json"), "w") as f:
        json.dump(messages, f)


def load_config():
    cfg = {}
    if os.path.exists(CFG):
        with open(CFG) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k, v = line.split("=", 1)
                    cfg[k.strip()] = v.strip()
    url = os.environ.get("AXONATE_URL", cfg.get("AXONATE_URL", "http://127.0.0.1:4100"))
    key = os.environ.get("AXONATE_KEY", cfg.get("AXONATE_KEY", ""))
    cf_id = os.environ.get("AXONATE_CF_CLIENT_ID", cfg.get("AXONATE_CF_CLIENT_ID", ""))
    cf_secret = os.environ.get("AXONATE_CF_CLIENT_SECRET", cfg.get("AXONATE_CF_CLIENT_SECRET", ""))
    model = os.environ.get("AXONATE_MODEL", cfg.get("AXONATE_MODEL", "claude"))
    system = os.environ.get("AXONATE_SYSTEM", cfg.get("AXONATE_SYSTEM", DEFAULT_SYSTEM))
    return url.rstrip("/"), key, cf_id, cf_secret, model, system


def save_config_kv(k, v):
    """Upsert key=value in ~/.config/axonate/config (preserve other lines)."""
    os.makedirs(os.path.dirname(CFG), exist_ok=True)
    lines, found = [], False
    if os.path.exists(CFG):
        with open(CFG) as f:
            for line in f:
                if line.strip().startswith(f"{k}="):
                    lines.append(f"{k}={v}\n"); found = True
                else:
                    lines.append(line)
    if not found:
        lines.append(f"{k}={v}\n")
    with open(CFG, "w") as f:
        f.writelines(lines)


def build_headers(key, cf_id="", cf_secret=""):
    """Request headers. Adds the Cloudflare Access service-token pair only when BOTH
    cf_id and cf_secret are set (so api.* edge gate passes); backward-compatible otherwise."""
    # custom User-Agent: urllib's default (Python-urllib/..) trips Cloudflare bot protection (1010)
    h = {"Content-Type": "application/json", "User-Agent": "axonate-ax/1.0"}
    if key:
        h["Authorization"] = f"Bearer {key}"
    if cf_id and cf_secret:
        h["CF-Access-Client-Id"] = cf_id
        h["CF-Access-Client-Secret"] = cf_secret
    return h


_C = {"dim": "\033[2m", "b": "\033[1m", "cy": "\033[36m", "gr": "\033[32m",
      "ye": "\033[33m", "z": "\033[0m"}


def fetch_models(url, headers):
    try:
        req = urllib.request.Request(f"{url}/v1/models", headers=headers)
        with urllib.request.urlopen(req, timeout=15) as r:
            return [m["id"] for m in json.loads(r.read()).get("data", [])]
    except Exception:
        return []


def print_banner(url, key, headers, model):
    c = _C
    models = fetch_models(url, headers)
    print(f"""{c['b']}{c['cy']}ax{c['z']} — Axonate gateway CLI
  {c['dim']}gateway{c['z']}  {url}
  {c['dim']}model  {c['z']}  {c['gr']}{model}{c['z']}  {c['dim']}(default; change: ax switch MODEL){c['z']}
  {c['dim']}models {c['z']}  {(', '.join(models)) if models else c['ye'] + '(unreachable — run: ax status)' + c['z']}
  {c['dim']}key    {c['z']}  {('…' + key[-6:]) if key else c['ye'] + 'MISSING (set AXONATE_KEY)' + c['z']}

{c['b']}usage{c['z']}
  ax "explain this error"                {c['dim']}# uses your default model ({model}){c['z']}
  ax -m codex "write a regex"            {c['dim']}# override model for one call{c['z']}
  git diff | ax "review this"            {c['dim']}# pipe stdin{c['z']}
  ax -s work "remember X"                {c['dim']}# named session, multi-turn{c['z']}

{c['b']}commands{c['z']}
  ax switch MODEL  {c['dim']}set the default model (claude | codex | auto){c['z']}
  ax models        {c['dim']}list available models{c['z']}
  ax status        {c['dim']}gateway/config + reachability{c['z']}
  ax usage         {c['dim']}your spend / budget / requests{c['z']}""")


def cmd_usage(url, headers):
    c = _C
    try:
        req = urllib.request.Request(f"{url}/v1/usage", headers=headers)
        with urllib.request.urlopen(req, timeout=15) as r:
            d = json.loads(r.read())
    except Exception as e:
        print(f"usage unavailable: {e}  (run: ax status)", file=sys.stderr)
        sys.exit(1)
    sp, bu, rem = d.get("spend"), d.get("budget"), d.get("remaining")
    print(f"{c['b']}usage — {d.get('email', '')}{c['z']}")
    print(f"  spend    : {('$%.4f' % sp) if sp is not None else '-'}")
    if bu:
        print(f"  budget   : ${bu}   {c['dim']}remaining{c['z']} ${rem}")
    print(f"  requests : {d.get('requests', 0)}")
    print(f"  tokens   : {d.get('tokens', 0)}")
    sys.exit(0)


def cmd_status(url, key, cf_id, headers, model):
    c = _C
    models = fetch_models(url, headers)
    ok = bool(models)
    print(f"{c['b']}axonate status{c['z']}")
    print(f"  gateway : {url}")
    print(f"  model   : {c['gr']}{model}{c['z']}  {c['dim']}(default){c['z']}")
    print(f"  key     : {('…' + key[-6:]) if key else c['ye'] + 'MISSING' + c['z']}")
    print(f"  cf-token: {'set' if cf_id else 'none'}")
    print(f"  models  : {', '.join(models) if models else '-'}")
    print(f"  reach   : {(c['gr'] + 'ok' + c['z']) if ok else c['ye'] + 'unreachable (check key/cf-token/url)' + c['z']}")
    sys.exit(0 if ok else 1)


def main():
    ap = argparse.ArgumentParser(prog="ax", description="Axonate gateway CLI", add_help=True)
    ap.add_argument("prompt", nargs="*", help="prompt text (or: models | status | usage | switch MODEL)")
    ap.add_argument("-m", "--model", default="",
                    help="model for this call: claude | codex | auto (overrides the saved default)")
    ap.add_argument("--no-stream", action="store_true", help="disable streaming")
    ap.add_argument("-s", "--session", default="", help="session name (persists history)")
    ap.add_argument("--new", action="store_true", help="reset the session before this turn")
    ap.add_argument("--system", default=None, help="override the system instruction for this call")
    ap.add_argument("--raw", action="store_true", help="send NO system instruction (model's raw behavior)")
    args = ap.parse_args()

    url, key, cf_id, cf_secret, saved_model, saved_system = load_config()
    headers = build_headers(key, cf_id, cf_secret)

    # switch the persisted default model:  ax switch codex   (or: ax use codex)
    if len(args.prompt) == 2 and args.prompt[0] in ("switch", "use"):
        m = args.prompt[1]
        avail = fetch_models(url, headers)
        if avail and m not in avail and m != "auto":
            print(f"{_C['ye']}'{m}' not in models{_C['z']}: {', '.join(avail)}", file=sys.stderr)
            sys.exit(1)
        save_config_kv("AXONATE_MODEL", m)
        print(f"{_C['gr']}default model -> {m}{_C['z']}  (override per call with -m)")
        return

    model = args.model or saved_model    # -m overrides the saved default

    # subcommands / banner
    if args.prompt == ["models"]:
        ms = fetch_models(url, headers)
        if not ms:
            print("no models (gateway unreachable or auth failed) — try: ax status", file=sys.stderr)
            sys.exit(1)
        print("\n".join(ms))
        return
    if args.prompt == ["status"]:
        cmd_status(url, key, cf_id, headers, model)
    if args.prompt == ["usage"]:
        cmd_usage(url, headers)

    prompt = " ".join(args.prompt)
    if not sys.stdin.isatty():                 # piped stdin -> append
        piped = sys.stdin.read().strip()
        prompt = f"{prompt}\n\n{piped}" if prompt else piped
    if not prompt:
        print_banner(url, key, headers, model)        # friendly banner instead of a bare error
        return

    stream = not args.no_stream
    history = [] if args.new else load_session(args.session)
    system = "" if args.raw else (args.system if args.system is not None else saved_system)
    sysmsg = [{"role": "system", "content": system}] if system else []
    messages = sysmsg + history + [{"role": "user", "content": prompt}]
    body = json.dumps({
        "model": model,
        "messages": messages,
        "stream": stream,
    }).encode()

    import itertools as _it
    import threading as _th
    import time as _t

    started = _t.time()
    _stop = _th.Event()

    def _spin():
        frames = _it.cycle("⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏")
        while not _stop.is_set():
            sys.stderr.write(f"\r{_C['dim']}{next(frames)} {model}…{_C['z']}")
            sys.stderr.flush()
            _t.sleep(0.1)
        sys.stderr.write("\r" + " " * 24 + "\r")
        sys.stderr.flush()

    spinner = _th.Thread(target=_spin, daemon=True)
    if sys.stderr.isatty():
        spinner.start()

    req = urllib.request.Request(f"{url}/v1/chat/completions", data=body, headers=headers)
    try:
        resp = urllib.request.urlopen(req)
    except urllib.error.HTTPError as e:
        _stop.set()
        detail = e.read().decode()
        try:
            detail = json.loads(detail).get("detail", detail)
        except Exception:
            pass
        hint = ""
        if e.code in (401, 403):
            hint = "  (check AXONATE_KEY + CF service-token — run: ax status)"
        elif e.code in (524, 504):
            hint = "  (backend slow / timed out — try a shorter prompt or -m codex)"
        print(f"{_C['ye']}error {e.code}{_C['z']}: {detail}{hint}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        _stop.set()
        print(f"cannot reach gateway at {url}: {e.reason}", file=sys.stderr)
        sys.exit(1)

    route = resp.headers.get("X-Router-Route") or model
    cache = resp.headers.get("X-Axonate-Cache", "")

    def _stop_spinner_once(_done=[False]):
        if not _done[0]:
            _stop.set()
            if spinner.is_alive():
                spinner.join(timeout=0.3)
            print(f"{_C['dim']}— {route}{(' · cached' if cache == 'hit' else '')} —{_C['z']}",
                  file=sys.stderr)
            _done[0] = True

    reply = ""
    if stream:
        for raw in resp:
            line = raw.decode().strip()
            if not line.startswith("data: "):     # skips ': keepalive' heartbeat comments too
                continue
            data = line[6:]
            if data == "[DONE]":
                break
            try:
                delta = json.loads(data)["choices"][0]["delta"].get("content", "")
            except (json.JSONDecodeError, KeyError, IndexError):
                continue
            if delta:
                _stop_spinner_once()
                reply += delta
                sys.stdout.write(delta)
                sys.stdout.flush()
        _stop_spinner_once()
        print()
    else:
        data = json.loads(resp.read())
        _stop_spinner_once()
        reply = data["choices"][0]["message"]["content"]
        print(reply)

    # footer: model + elapsed (+ a token count when non-stream gives usage)
    elapsed = _t.time() - started
    print(f"{_C['dim']}[{route} · {elapsed:.1f}s]{_C['z']}", file=sys.stderr)

    if args.session and reply:
        # persist history WITHOUT the system message (it's re-prepended each turn)
        convo = [m for m in messages if m["role"] != "system"]
        save_session(args.session, convo + [{"role": "assistant", "content": reply}])


if __name__ == "__main__":
    main()
