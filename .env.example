# Axonate — copy to .env and fill. NEVER commit the real .env.
# Compose reads this for both poc and prod (profile picks which services start).

# ---- LiteLLM ----
LITELLM_MASTER_KEY=sk-master-change-me           # admin/master key for the proxy
LITELLM_SALT_KEY=salt-change-me-32chars-min      # encrypts stored provider keys in DB
SLACK_WEBHOOK_URL=                               # spend-spike alert + daily digest (empty = off)

# ---- Postgres (axonate-db) ----
POSTGRES_USER=axonate
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=axonate

# ---- Adapter (POC only, disposable) ----
ADAPTER_TOKEN=adapter-shared-secret-change-me    # litellm->adapter auth; "" disables
ADAPTER_TIMEOUT=300                              # subprocess timeout (s)
CLAUDE_OAUTH_TOKEN_A=                            # from `make login-claude ACCT=acctA` -> setup-token
CLAUDE_OAUTH_TOKEN_B=                            # second account (failover); optional
CLAUDE_FLAGS="--permission-mode plan"            # read-only default flags (quote: has a space)
CODEX_FLAGS="--sandbox read-only"               # read-only default flags
CLAUDE_CODE_FLAGS="--permission-mode acceptEdits"  # write profile flags
CODEX_CODE_FLAGS="--sandbox workspace-write"     # write profile flags

# ---- MiniMax subscription (POC) ----
MINIMAX_API_KEY=mm-change-me
MINIMAX_BASE_URL=https://api.minimax.io/v1

# ---- Router ----
AUTH_MODE=dev                                    # dev = no SSO (local); cloudflare = verify Access JWT
ROUTER_DEV_USER=dev@local                        # identity used when AUTH_MODE=dev
LOG_PROMPTS=false                                # privacy: prompt-content logging opt-in only

# ---- Cloudflare Access (prod / Phase 4) ----
CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
CF_ACCESS_AUD=                                   # Access application AUD tag
CLOUDFLARE_TUNNEL_TOKEN=                         # token for axonate-cloudflared

# ---- Production provider keys (prod profile only) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
