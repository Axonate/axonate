# PROD overlay — copy values into .env for production.
# Backends: real provider APIs. Adapter NOT started (poc profile only). SSO enforced.
AUTH_MODE=cloudflare
LOG_PROMPTS=false

# Cloudflare Access (Google IdP) — origin verifies the Access JWT
CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
CF_ACCESS_AUD=your-access-app-aud-tag
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# real provider keys (used by services/litellm/litellm_config.prod.yaml)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# every authorized email must have a provisioned virtual key in config/users.yaml
