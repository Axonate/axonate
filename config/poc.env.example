# POC overlay — copy values into .env for local / single-user POC.
# Backends: CLI adapter (claude/codex) + MiniMax subscription.
AUTH_MODE=dev
ROUTER_DEV_USER=dev@local
LOG_PROMPTS=false

ADAPTER_TOKEN=adapter-shared-secret-change-me
CLAUDE_FLAGS="--permission-mode plan"
CODEX_FLAGS="--sandbox read-only"

MINIMAX_API_KEY=mm-change-me
MINIMAX_BASE_URL=https://api.minimax.io/v1

# adapter logins live in named volumes — log in once with `make login-claude` / `make login-codex`.
